import pandas as pd

# Load dataset
df = pd.read_csv(r"C:\Users\HP\Documents\dataset_titanic\Titanic-Dataset.csv")

# Basic info
print(df.info())        # data types & nulls
print(df.isnull().sum()) # count of missing values
print(df.head())        # preview

# Fill numerical columns with median (better for skewed data)
df['Age'] = df['Age'].fillna(df['Age'].median())

# Fill categorical columns with mode
df['Embarked'] = df['Embarked'].fillna(df['Embarked'].mode()[0])

# Drop column with too many nulls (optional)
df = df.drop(columns=['Cabin'])

# Label Encoding (for binary categories)
df['Sex'] = df['Sex'].map({'male': 0, 'female': 1})

# One-Hot Encoding (for multiple categories)
df = pd.get_dummies(df, columns=['Embarked'], drop_first=True)

from sklearn.preprocessing import StandardScaler

scaler = StandardScaler()

# Select numerical columns
num_cols = ['Age', 'Fare', 'SibSp', 'Parch']

df[num_cols] = scaler.fit_transform(df[num_cols])

import matplotlib.pyplot as plt
import seaborn as sns

# Boxplot
for col in num_cols:
    plt.figure()
    sns.boxplot(x=df[col])
    plt.title(f'Boxplot of {col}')
    plt.show()

# Remove outliers using IQR method
for col in num_cols:
    Q1 = df[col].quantile(0.25)
    Q3 = df[col].quantile(0.75)
    IQR = Q3 - Q1

    lower = Q1 - 1.5 * IQR
    upper = Q3 + 1.5 * IQR

    df = df[(df[col] >= lower) & (df[col] <= upper)]

    print(df.shape)
print(df.head())
